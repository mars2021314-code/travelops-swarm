OPENAI_API_KEY=

# Primary LLM provider.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Runtime services.
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
DATABASE_URL=
CHECKPOINT_DATABASE_URL=

# Local data.
SQLITE_DB_PATH=./customer_support_chat/data/travel2.sqlite
QDRANT_PATH=./customer_support_chat/data/qdrant_local
REQUIRE_QDRANT_SERVER=false
REQUIRE_PERSISTENT_CHECKPOINT=false

# API behavior.
LOG_LEVEL=INFO
CHAT_CONCURRENCY_LIMIT=20
CHAT_DISTRIBUTED_CONCURRENCY_LIMIT=20
CHAT_REQUEST_TIMEOUT_SECONDS=180
CHAT_USER_RATE_LIMIT_PER_MINUTE=60
CHAT_IP_RATE_LIMIT_PER_MINUTE=120
CHAT_GLOBAL_RATE_LIMIT_PER_MINUTE=600
CHAT_RATE_LIMIT_BURST=20
CHAT_CACHE_TTL_SECONDS=3600
CHAT_IDEMPOTENCY_TTL_SECONDS=3600
CHAT_IDEMPOTENCY_PENDING_TTL_SECONDS=300
REDIS_QUERY_CACHE_TTL_SECONDS=300
REDIS_WRITE_LOCK_TTL_SECONDS=30
REDIS_LOCK_WAIT_TIMEOUT_SECONDS=5

# Optional tracing.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=

LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
MEMORY_AUDIT_LOG_ENABLED=false
LIMIT_ROWS=100
